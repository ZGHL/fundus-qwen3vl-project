+def _flatten_prompt_token_ids(seq) -> list[int]:
+    r"""Multimodal datasets may nest token rows; vLLM expects ``List[int]``."""
+    if seq is None:
+        return []
+    if isinstance(seq, np.ndarray):
+        seq = seq.tolist()
+    if len(seq) == 0:
+        return []
+    if isinstance(seq[0], (list, tuple)):
+        flat: list[int] = []
+        for item in seq:
+            if isinstance(item, (list, tuple, np.ndarray)):
+                flat.extend(int(x) for x in item)
+            else:
+                flat.append(int(item))
+        return flat
+    return [int(x) for x in seq]
+
+
+def _seq_to_list(seq) -> list:
+    if hasattr(seq, "detach"):  # torch.Tensor
+        return seq.detach().cpu().tolist()
+    if isinstance(seq, np.ndarray):
+        return seq.tolist()
+    return list(seq)
+
+
+def _prompt_token_ids_from_supervised_row(input_ids, labels) -> list[int]:
+    r"""Keep only the prompt (supervised SFT masks reference tokens with ``IGNORE_INDEX``).
+
+    ``train``-stage SFT datasets include the reference answer in ``input_ids``. HF predict on eval uses a
+    prompt-only processor; vLLM must truncate the same way, otherwise the context already ends with EOS
+    and generation returns empty text.
+    """
+    ids = _seq_to_list(input_ids)
+    if labels is None:
+        return ids
+
+    lab = _seq_to_list(labels)
+    if not lab or len(lab) != len(ids):
+        return ids
+    for i, lid in enumerate(lab):
+        if lid != IGNORE_INDEX:
+            return ids[:i]
+    return ids
+
